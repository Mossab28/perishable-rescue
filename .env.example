# Copy to .env and fill in. The pipeline runs WITHOUT this (rule-based fallback),
# but the three reasoning agents (Risk, Need & Equity, Coordinator) make real LLM
# calls when a key is present.
#
# Works with any OpenAI-compatible endpoint. Examples:
#   OpenAI:     OPENAI_BASE_URL=https://api.openai.com/v1     OPENAI_MODEL=gpt-4o
#   OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1  OPENAI_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o-mini
